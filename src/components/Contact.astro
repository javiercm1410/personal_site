---
import Button from '@components/ui/Button.astro';
import Social from '@components/ui/Social.astro';
import pkg from '../../package.json';

const version = pkg.version;
---

<section
	data-testid="contact"
	id="contact"
	class="relative z-10 mb-5 mt-10 flex flex-col flex-wrap items-center justify-center gap-8 text-on-surface"
>
	<h2 class="text-3xl text-primary text-glow lg:text-4xl">contact</h2>
	<p class="max-w-xl text-center text-base text-on-surface/70">
		Let's build something together. Reach out through any of the channels below.
	</p>
	<Button size={'lg'} href="/#main" style={'primary'} name="Contact">Go back!</Button>
	<hr class="w-1/2 border-primary/30" />
	<div class="flex flex-col gap-8 lg:flex lg:flex-row lg:gap-20">
		<Social />
	</div>

	<footer class="w-full py-1 text-center text-sm text-on-surface/50">
		<p>© 2026 Javier Carrillo. All rights reserved.</p>
		<p>Version: {version}</p>
	</footer>
</section>
