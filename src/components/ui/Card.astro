---
interface Props {
	url?: string;
	alt?: string;
	title?: string;
	image?: string;
	description: string;
	children?: HTMLElement | HTMLElement[];
}

const {
	url = '#',
	alt = 'Project image',
	image = '#',
	description = 'Project Description',
	title = 'Project title',
} = Astro.props;
---

<section class="w-full p-4 md:w-1/2 lg:w-1/3">
	<article
		data-testId="card"
		class="rounded-xl border border-primary/20 bg-on-surface/[0.03] p-3 shadow-lg transition duration-200 hover:-translate-y-1 hover:border-primary/60 hover:shadow-[0_0_25px_rgba(170,199,255,0.15)]"
	>
		<a href={url} aria-label="link to project">
			<div class="relative flex items-end overflow-hidden rounded-xl">
				<img src={image} alt={alt} width="400" height="400" loading="eager" />
			</div>
			<div class="mt-3 flex flex-col items-center p-2">
				<h3 class="text-xl text-primary lg:text-3xl">{title}</h3>
				<p class="text-s text-center w-2/3 text-on-surface/70">{description}</p>
			</div>
		</a>
	</article>
</section>
