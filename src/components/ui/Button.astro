---
interface Props {
	size?: 'sm' | 'md' | 'lg';
	block?: boolean;
	style?: 'primary';
	class?: string;
	href?: string;
	[x: string]: any;
}

const { size = 'md', style = 'primary', block, class: className, href, ...rest } = Astro.props;

const sizes = {
	sm: 'px-4 py-1.5',
	md: 'px-5 py-2.5',
	lg: 'px-6 py-3',
};

const styles = {
	primary: 'bg-transparent text-on-surface border border-primary/50 hover:bg-primary hover:text-surface hover:border-primary hover:shadow-[0_0_20px_rgba(170,199,255,0.4)]',
};
---

{href ? (
	<a
		{...rest}
		href={href}
		class:list={[
			'rounded-xl text-center transition focus-visible:ring-2 ring-offset-2 ring-primary inline-block',
			block && 'w-full',
			sizes[size],
			styles[style],
			className,
		]}
	>
		<slot />
	</a>
) : (
	<button
		{...rest}
		class:list={[
			'rounded-xl text-center transition focus-visible:ring-2 ring-offset-2 ring-primary',
			block && 'w-full',
			sizes[size],
			styles[style],
			className,
		]}
	>
		<slot />
	</button>
)}
